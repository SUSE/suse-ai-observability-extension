  - id: -579
    name: Average Tokens per Request
    description: Input and output tokens per inference call. Indicates verbosity or prompt inflation. Higher values drive cost and latency.
    queries:
      - expression: sum(rate(gen_ai_client_token_usage_sum{service_name="${name}"}[5m])) / sum(rate(gen_ai_client_request_count_total{service_name="${name}"}[5m]))
        alias: "AVG Tokens/Request"
        primary: true
    scope:  type in ("service", "application") AND label IN ("suse.ai.category:application")
    identifier: urn:stackpack:suse-ai:shared:metric-binding:application:genai-app-average-tokens-per-request
    unit: short
    chartType: line
    priority: high
    enabled: true
    layout:
      metricPerspective:
        tab: LLM
        section: Tokens
      componentSummary:
        weight: 3
    _type: MetricBinding

  - id: -580
    name: Token Throughput
    description: Aggregate input + output tokens processed per second. Similar to a GPU-workload proxy.
    queries:
      - expression: sum by(gen_ai_request_model) (rate(gen_ai_client_token_usage_sum{service_name="${name}"}[${__interval}]))/sum(rate(gen_ai_client_request_count_total{service_name="${name}"}[${__interval}]))
        alias: "${gen_ai_request_model}"
        primary: true
    scope:  type in ("service", "application") AND label IN ("suse.ai.category:application")
    identifier: urn:stackpack:suse-ai:shared:metric-binding:application:genai-app-tokens-throughput
    unit: cps
    chartType: line
    priority: high
    enabled: true
    layout:
      metricPerspective:
        tab: LLM
        section: Tokens
      componentSummary:
        weight: 3
    _type: MetricBinding

  - id: -581
    name: Cost per 1 K Tokens (USD)
    description: Expenditure to 1000-token chunks, enabling cross-model cost benchmarking.
    queries:
      - expression: (sum by (gen_ai_request_model) (rate(gen_ai_client_operation_cost_USD_sum{service_name="${name}"}[${__rate_interval}])) / sum by(gen_ai_request_model) (rate(gen_ai_client_token_usage_sum{service_name="${name}"}[${__rate_interval}]))) * 1000
        alias: "${gen_ai_request_model}"
        primary: true
    scope:  type in ("service", "application") AND label IN ("suse.ai.category:application")
    identifier: urn:stackpack:suse-ai:shared:metric-binding:application:genai-app-cost-per-1k-tokens
    unit: currencyUSD
    chartType: line
    priority: high
    enabled: true
    layout:
      metricPerspective:
        tab: LLM
        section: Cost
      componentSummary:
        weight: 3
    _type: MetricBinding

  - id: -584
    name: Operation Duration (P95)
    description: 95th percentile latency of GenAI inference calls. Helps detect slow models or degraded backends.
    queries:
      - expression: histogram_quantile(0.95, sum by (gen_ai_request_model, le) (rate(gen_ai_client_operation_duration_seconds_bucket{service_name="${name}"}[5m])))
        alias: "${gen_ai_request_model}"
        primary: true
    scope:  type in ("service", "application") AND label IN ("suse.ai.category:application")
    identifier: urn:stackpack:suse-ai:shared:metric-binding:application:genai-app-operation-duration-p95
    unit: s
    chartType: line
    priority: high
    enabled: true
    layout:
      metricPerspective:
        tab: LLM
        section: Performance
      componentSummary:
        weight: 3
    _type: MetricBinding

