  - id: -630
    name: "Request Rate"
    description: "Inference requests per second per InferenceService."
    queries:
      - expression: 'sum by (service_name) (rate(revision_request_count{namespace=~".+"}[${__rate_interval}]))'
        alias: "${service_name}"
        primary: true
    scope: 'type = "inference-engine.kserve"'
    identifier: "urn:stackpack:suse-ai:shared:metric-binding:kserve:request-rate"
    unit: reqps
    chartType: line
    priority: high
    enabled: true
    layout:
      metricPerspective:
        tab: KServe
        section: Performance
      componentSummary:
        weight: 3
    _type: MetricBinding

  - id: -631
    name: "Request Latency"
    description: "P50/P95/P99 of end-to-end request latency per InferenceService."
    queries:
      - expression: 'histogram_quantile(0.99, sum by (service_name, le) (rate(revision_app_request_latencies_bucket[${__rate_interval}])))'
        alias: "P99"
      - expression: 'histogram_quantile(0.95, sum by (service_name, le) (rate(revision_app_request_latencies_bucket[${__rate_interval}])))'
        alias: "P95"
        primary: true
      - expression: 'histogram_quantile(0.50, sum by (service_name, le) (rate(revision_app_request_latencies_bucket[${__rate_interval}])))'
        alias: "P50"
    scope: 'type = "inference-engine.kserve"'
    identifier: "urn:stackpack:suse-ai:shared:metric-binding:kserve:latency-p95"
    unit: ms
    chartType: line
    priority: high
    enabled: true
    layout:
      metricPerspective:
        tab: KServe
        section: Performance
      componentSummary:
        weight: 3
    _type: MetricBinding

  - id: -632
    name: "Per-Step Latency P95"
    description: "P95 of preprocess, predict, and postprocess steps."
    queries:
      - expression: 'histogram_quantile(0.95, sum by (le) (rate(request_preprocess_seconds_bucket[${__rate_interval}])))'
        alias: "preprocess P95"
      - expression: 'histogram_quantile(0.95, sum by (le) (rate(request_predict_seconds_bucket[${__rate_interval}])))'
        alias: "predict P95"
        primary: true
      - expression: 'histogram_quantile(0.95, sum by (le) (rate(request_postprocess_seconds_bucket[${__rate_interval}])))'
        alias: "postprocess P95"
    scope: 'type = "inference-engine.kserve"'
    identifier: "urn:stackpack:suse-ai:shared:metric-binding:kserve:step-latency"
    unit: s
    chartType: line
    priority: high
    enabled: true
    layout:
      metricPerspective:
        tab: KServe
        section: Runtime
      componentSummary:
        weight: 2
    _type: MetricBinding

  - id: -633
    name: "Queue Depth"
    description: "Maximum queue depth across InferenceService pods."
    queries:
      - expression: 'max by (service_name) (queue_depth)'
        alias: "${service_name}"
        primary: true
    scope: 'type = "inference-engine.kserve"'
    identifier: "urn:stackpack:suse-ai:shared:metric-binding:kserve:queue-depth"
    unit: short
    chartType: line
    tags:
      experimental_chartType: Gauge
      enableGaugeChart: "1"
    priority: high
    enabled: true
    layout:
      metricPerspective:
        tab: KServe
        section: Runtime
      componentSummary:
        weight: 2
    _type: MetricBinding

  - id: -634
    name: "Model Load Duration"
    description: "Latest model load duration in seconds."
    queries:
      - expression: 'max by (service_name) (model_load_seconds)'
        alias: "${service_name}"
        primary: true
    scope: 'type = "inference-engine.kserve"'
    identifier: "urn:stackpack:suse-ai:shared:metric-binding:kserve:model-load-duration"
    unit: s
    chartType: line
    tags:
      experimental_chartType: Gauge
      enableGaugeChart: "1"
    priority: high
    enabled: true
    layout:
      metricPerspective:
        tab: KServe
        section: Runtime
      componentSummary:
        weight: 2
    _type: MetricBinding

  - id: -635
    name: "Error Ratio"
    description: "Ratio of 5xx responses to total requests per InferenceService."
    queries:
      - expression: '(sum by (service_name) (rate(revision_request_count{response_code_class="5xx"}[${__rate_interval}])) / sum by (service_name) (rate(revision_request_count[${__rate_interval}]))) or vector(0)'
        alias: "${service_name}"
        primary: true
    scope: 'type = "inference-engine.kserve"'
    identifier: "urn:stackpack:suse-ai:shared:metric-binding:kserve:error-ratio"
    unit: percentunit
    chartType: line
    priority: high
    enabled: true
    layout:
      metricPerspective:
        tab: KServe
        section: Performance
      componentSummary:
        weight: 3
    _type: MetricBinding
