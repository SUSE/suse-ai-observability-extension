  - _type: MetricBinding
    id: -2000
    name: LLM Request Rate
    identifier: urn:stackpack:suse-ai:shared:metric-binding:request-rate
    unit: reqps
    chartType: line
    priority: high
    enabled: true
    scope: label IN ("suse.ai.managed:true") AND type IN ("ui.open-webui", "inference-engine.vllm", "inference-engine.ollama", "model-proxy.litellm", "application", "agent")
    queries:
      - expression: sum by (gen_ai_request_model) (rate(gen_ai_client_operation_duration_seconds_count{ suse_ai_component_name="${name}" }[${__rate_interval}]))
        alias: "${gen_ai_request_model}"
    layout:
      metricPerspective:
        tab: LLM
        section: Utilization
      componentSummary:
        weight: 3

  - _type: MetricBinding
    id: -2001
    name: Average Tokens per Request
    identifier: urn:stackpack:suse-ai:shared:metric-binding:average-tokens-per-request
    unit: short
    chartType: line
    priority: high
    enabled: true
    scope: label IN ("suse.ai.managed:true") AND type IN ("ui.open-webui", "inference-engine.vllm", "inference-engine.ollama", "model-proxy.litellm", "application", "agent")
    queries:
      - expression: sum by (gen_ai_request_model) (rate(gen_ai_client_token_usage_sum{suse_ai_component_name="${name}"}[5m])) / sum by (gen_ai_request_model) (rate(gen_ai_client_operation_duration_seconds_count{suse_ai_component_name="${name}"}[5m]))
        alias: "${gen_ai_request_model}"
    layout:
      metricPerspective:
        tab: LLM
        section: Tokens
      componentSummary:
        weight: 3

  - _type: MetricBinding
    id: -2002
    name: Total Usage Cost
    identifier: urn:stackpack:suse-ai:shared:metric-binding:total-usage-cost
    unit: currencyUSD
    chartType: line
    tags:
      experimental_chartType: Gauge
      enableGaugeChart: "1"
    priority: high
    enabled: true
    scope: label IN ("suse.ai.managed:true") AND type IN ("ui.open-webui", "inference-engine.vllm", "inference-engine.ollama", "model-proxy.litellm", "application", "agent")
    queries:
      - expression: sum(gen_ai_client_operation_cost_USD_sum{ suse_ai_component_name="${name}" })
        alias: Total Cost
    layout:
      metricPerspective:
        tab: LLM
        section: Cost
      componentSummary:
        weight: 3

  - _type: MetricBinding
    id: -2003
    name: Operation Duration (P95)
    identifier: urn:stackpack:suse-ai:shared:metric-binding:operation-duration-p95
    unit: s
    chartType: line
    priority: high
    enabled: true
    scope: label IN ("suse.ai.managed:true") AND type IN ("ui.open-webui", "inference-engine.vllm", "inference-engine.ollama", "model-proxy.litellm", "application", "agent")
    queries:
      - expression: histogram_quantile(0.95, sum by (gen_ai_request_model, le) (rate(gen_ai_client_operation_duration_seconds_bucket{suse_ai_component_name="${name}"}[5m])))
        alias: "${gen_ai_request_model}"
    layout:
      metricPerspective:
        tab: LLM
        section: Performance
      componentSummary:
        weight: 3

  - _type: MetricBinding
    id: -2004
    name: Token Usage by Type
    identifier: urn:stackpack:suse-ai:shared:metric-binding:token-usage-by-type
    unit: short
    chartType: line
    priority: medium
    enabled: true
    scope: label IN ("suse.ai.managed:true") AND type IN ("ui.open-webui", "inference-engine.vllm", "inference-engine.ollama", "model-proxy.litellm", "application", "agent")
    queries:
      - expression: sum by (gen_ai_request_model) (rate(gen_ai_client_token_usage_sum{suse_ai_component_name="${name}", gen_ai_token_type="input"}[5m]))
        alias: "${gen_ai_request_model} (Input)"
      - expression: sum by (gen_ai_request_model) (rate(gen_ai_client_token_usage_sum{suse_ai_component_name="${name}", gen_ai_token_type="output"}[5m]))
        alias: "${gen_ai_request_model} (Output)"
    layout:
      metricPerspective:
        tab: LLM
        section: Tokens
      componentSummary:
        weight: 2
