  - id: -704
    name: Free Disk (%)
    description: "Returns % of disk free per node"
    queries:
      - expression: (elasticsearch_node_fs_disk_free_bytes{elasticsearch_cluster_name="elasticsearch-cluster"} / elasticsearch_node_fs_disk_total_bytes{elasticsearch_cluster_name="elasticsearch-cluster"}) * 100
        alias: '${elasticsearch_node_name}'
        primary: true
    scope:  type in ("search-engine.elasticsearch")
    identifier: urn:stackpack:suse-ai:shared:metric-binding:elasticsearch:vectordb-free-space
    unit: short
    chartType: line
    priority: high
    enabled: true
    layout:
      metricPerspective:
        tab: VectorDB
        section: Disk Space
      componentSummary:
        weight: 3
    _type: MetricBinding
  - id: -705
    name: Completed Operations Count
    description: "Returns the amount of operations completed"
    queries:
      - expression: sum(elasticsearch_index_operations_completed_total{elasticsearch_cluster_name="elasticsearch-cluster"}) by (operation)
        alias: '${operation}'
        primary: true
    scope:  type in ("search-engine.elasticsearch")
    identifier: urn:stackpack:suse-ai:shared:metric-binding:elasticsearch:vectordb-operation
    unit: short
    chartType: line
    priority: high
    enabled: true
    layout:
      metricPerspective:
        tab: VectorDB
        section: Operations
      componentSummary:
        weight: 3
    _type: MetricBinding
