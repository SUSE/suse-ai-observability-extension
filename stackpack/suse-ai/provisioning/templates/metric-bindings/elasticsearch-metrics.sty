
  - id: -700
    name: Pending Tasks
    description: "The total number of pending tasks"
    queries:
      - expression: sum(elasticsearch_cluster_pending_tasks{elasticsearch_cluster_name="elasticsearch-cluster"})
        alias: Pending tasks count
        primary: true
    scope:  type in ("search-engine.elasticsearch")
    identifier: urn:stackpack:suse-ai:shared:metric-binding:elasticsearch:vectordb-pending-tasks-count
    unit: short
    chartType: line
    tags:
      experimental_chartType: Gauge
      enableGaugeChart: "1"
    priority: high
    enabled: true
    layout:
      metricPerspective:
        tab: VectorDB
        section: Request
      componentSummary:
        weight: 3
    _type: MetricBinding
