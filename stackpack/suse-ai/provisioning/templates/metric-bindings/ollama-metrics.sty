        alias: Request Rate
        primary: true
    scope:  type in ("inference-engine.ollama", "inference-engine")
    identifier: urn:stackpack:suse-ai:shared:metric-binding:ollama:genai-system-request-rate
    unit: reqps
    chartType: line
    priority: high
    enabled: true
    layout:
      metricPerspective:
        tab: LLM
        section: Utilization
      componentSummary:
        weight: 3
    _type: MetricBinding
