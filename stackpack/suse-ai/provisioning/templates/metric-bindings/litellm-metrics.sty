        alias: 'P95'
        primary: true
      - expression: histogram_quantile(0.50, sum by (le) (rate(litellm_llm_api_time_to_first_token_metric_bucket{}[${__rate_interval}])))
        alias: 'P50'
    scope: type in ("model-proxy.litellm")
    identifier: urn:stackpack:suse-ai:shared:metric-binding:litellm:ttft
    unit: seconds
    chartType: line
    priority: high
    enabled: true
    layout:
      metricPerspective:
        tab: Proxy
        section: Latency
      componentSummary:
        weight: 3
    _type: MetricBinding

  - id: -635
    name: Total Spend
    description: "Total cost accumulated through the LiteLLM proxy"
    queries:
      - expression: sum(litellm_spend_metric{})
        alias: Total Spend
        primary: true
      - expression: sum by (model) (litellm_spend_metric{})
        alias: "${model}"
    scope: type in ("model-proxy.litellm")
    identifier: urn:stackpack:suse-ai:shared:metric-binding:litellm:total-spend
    unit: currencyUSD
    chartType: line
    tags:
      experimental_chartType: Gauge
      enableGaugeChart: "1"
    priority: high
    enabled: true
    layout:
      metricPerspective:
        tab: Proxy
        section: Cost
      componentSummary:
        weight: 3
    _type: MetricBinding

  - id: -636
    name: Token Usage
    description: "Input and output token consumption through the LiteLLM proxy"
    queries:
      - expression: sum(rate(litellm_input_tokens_metric{}[${__rate_interval}]))
        alias: Input Tokens/s
      - expression: sum(rate(litellm_output_tokens_metric{}[${__rate_interval}]))
        alias: Output Tokens/s
      - expression: sum(rate(litellm_total_tokens_metric{}[${__rate_interval}]))
        alias: Total Tokens/s
        primary: true
    scope: type in ("model-proxy.litellm")
    identifier: urn:stackpack:suse-ai:shared:metric-binding:litellm:token-usage
    unit: short
    chartType: line
    priority: high
    enabled: true
    layout:
      metricPerspective:
        tab: Proxy
        section: Tokens
      componentSummary:
        weight: 3
    _type: MetricBinding

  - id: -637
