
  # =============================================
  # LiteLLM Proxy Scope (model-proxy.litellm)
  # =============================================

  - id: -630
    name: Proxy Request Rate
    description: "Rate of total requests handled by the LiteLLM proxy"
    queries:
      - expression: sum(rate(litellm_proxy_total_requests_metric{}[${__rate_interval}]))
        alias: Total
        primary: true
      - expression: sum by (requested_model) (rate(litellm_proxy_total_requests_metric{}[${__rate_interval}]))
        alias: "${requested_model}"
    scope: type in ("model-proxy.litellm")
    identifier: urn:stackpack:suse-ai:shared:metric-binding:litellm:proxy-request-rate
    unit: reqps
    chartType: line
    priority: high
    enabled: true
    layout:
      metricPerspective:
        tab: Proxy
        section: Requests
      componentSummary:
        weight: 8
    _type: MetricBinding

  - id: -631
    name: Proxy Failed Request Rate
    description: "Rate of failed requests returned by the LiteLLM proxy"
    queries:
      - expression: sum(rate(litellm_proxy_failed_requests_metric{}[${__rate_interval}]))
        alias: Total Failures
        primary: true
      - expression: sum by (exception_status) (rate(litellm_proxy_failed_requests_metric{}[${__rate_interval}]))
        alias: "${exception_status}"
    scope: type in ("model-proxy.litellm")
    identifier: urn:stackpack:suse-ai:shared:metric-binding:litellm:proxy-failed-request-rate
    unit: reqps
    chartType: line
    priority: high
    enabled: true
    layout:
      metricPerspective:
        tab: Proxy
        section: Requests
      componentSummary:
        weight: 8
    _type: MetricBinding

  - id: -632
    name: Request Total Latency
    description: "End-to-end latency of requests through the LiteLLM proxy"
    queries:
      - expression: histogram_quantile(0.99, sum by (le) (rate(litellm_request_total_latency_metric_bucket{}[${__rate_interval}])))
        alias: 'P99'
      - expression: histogram_quantile(0.95, sum by (le) (rate(litellm_request_total_latency_metric_bucket{}[${__rate_interval}])))
        alias: 'P95'
        primary: true
      - expression: histogram_quantile(0.50, sum by (le) (rate(litellm_request_total_latency_metric_bucket{}[${__rate_interval}])))
        alias: 'P50'
      - expression: sum(rate(litellm_request_total_latency_metric_sum{}[${__rate_interval}])) / sum(rate(litellm_request_total_latency_metric_count{}[${__rate_interval}]))
        alias: 'Avg'
    scope: type in ("model-proxy.litellm")
    identifier: urn:stackpack:suse-ai:shared:metric-binding:litellm:request-total-latency
    unit: seconds
    chartType: line
    priority: high
    enabled: true
    layout:
      metricPerspective:
        tab: Proxy
        section: Latency
      componentSummary:
        weight: 8
    _type: MetricBinding

  - id: -633
    name: LLM API Latency
    description: "Latency of upstream LLM API calls made by LiteLLM"
    queries:
      - expression: histogram_quantile(0.99, sum by (le) (rate(litellm_llm_api_latency_metric_bucket{}[${__rate_interval}])))
        alias: 'P99'
      - expression: histogram_quantile(0.95, sum by (le) (rate(litellm_llm_api_latency_metric_bucket{}[${__rate_interval}])))
        alias: 'P95'
        primary: true
      - expression: histogram_quantile(0.50, sum by (le) (rate(litellm_llm_api_latency_metric_bucket{}[${__rate_interval}])))
        alias: 'P50'
      - expression: sum(rate(litellm_llm_api_latency_metric_sum{}[${__rate_interval}])) / sum(rate(litellm_llm_api_latency_metric_count{}[${__rate_interval}]))
        alias: 'Avg'
    scope: type in ("model-proxy.litellm")
    identifier: urn:stackpack:suse-ai:shared:metric-binding:litellm:llm-api-latency
    unit: seconds
    chartType: line
    priority: high
    enabled: true
    layout:
      metricPerspective:
        tab: Proxy
        section: Latency
      componentSummary:
        weight: 3
    _type: MetricBinding

  - id: -634
    name: Time to First Token
    description: "Time to first token for streaming LLM requests"
    queries:
      - expression: histogram_quantile(0.99, sum by (le) (rate(litellm_llm_api_time_to_first_token_metric_bucket{}[${__rate_interval}])))
        alias: 'P99'
