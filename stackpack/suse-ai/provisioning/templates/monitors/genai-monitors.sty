  - _type: Monitor
    id: -3000
    name: GPU Node NVIDIA XID Errors
    identifier: urn:stackpack:suse-ai:shared:monitor:nvidia-xid-errors
    description: Indicates if a GPU Node is emitting an XID error for NVIDIA graphics cards.
    intervalSeconds: 60
    status: ENABLED
    function: {{ get "urn:stackpack:common:monitor-function:threshold" }}
    arguments:
      threshold: 1.0
      comparator: GTE
      failureState: CRITICAL
      metric:
        aliasTemplate: "XID Error ${err_code}"
        query: max by (err_code, err_msg, k8s_node_name) (max_over_time(DCGM_FI_DEV_XID_ERRORS[5m]))
        unit: short
      titleTemplate: "NVIDIA XID Error ${err_code} - ${err_msg}"
      urnTemplate: "urn:host:/${k8s_node_name}"

  - _type: Monitor
    id: -3001
    name: GenAI Application Metric Stream Active
    identifier: urn:stackpack:suse-ai:shared:monitor:genai-app-metric-stream-active
    description: Indicates if GenAI application metrics are being received from a component.
    intervalSeconds: 60
    status: ENABLED
    function: {{ get "urn:stackpack:common:monitor-function:threshold" }}
    arguments:
      threshold: 0.0001
      comparator: LTE
      failureState: DEVIATING
      metric:
        aliasTemplate: "Requests ${suse_ai_component_name}"
        query: sum(rate(gen_ai_client_operation_duration_seconds_count{}[5m])) by (suse_ai_component_name, suse_ai_component_type)
        unit: reqps
      titleTemplate: "GenAI data from ${suse_ai_component_name}"
      urnTemplate: "urn:suse-ai:product:${suse_ai_component_type}:${suse_ai_component_name}"

  - _type: Monitor
    id: -3015
    name: Application Span Error Ratio
    identifier: urn:stackpack:suse-ai:shared:monitor:application-span-error-ratio
    description: |
      Percentage of spans that are in an error state for the application.
      Triggers when more than 5% of tracing data contains errors.
    intervalSeconds: 60
    status: ENABLED
    tags: ["application", "traces"]
    function: {{ get "urn:stackpack:common:monitor-function:threshold" }}
    arguments:
      threshold: 5
      comparator: GT
      failureState: DEVIATING
      metric:
        query: 'sum by(service_name)(rate(otel_span_calls_total{status_code="STATUS_CODE_ERROR"}[5m]) or (present_over_time(otel_span_calls_total{}[5m]) - 1)) / sum by(service_name)(rate(otel_span_calls_total{}[5m])) * 100'
        aliasTemplate: "Error ratio (errors/total)"
        unit: percent
      titleTemplate: "Span error ratio"
      urnTemplate: "urn:suse-ai:product:application:${service_name}"
    remediationHint: {{ include "templates/monitors/application-span-error-ratio/remediation-hint.md.hbs" "identity" }}

