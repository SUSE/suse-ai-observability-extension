        - _type: "ComponentTypeField"
          fieldId: "type"
          label:
            title: "Type"
          valueExtractor:
            _type: "ComponentTypeSource"
          display:
            _type: "TagDisplay"
        - _type: "ComponentTypeField"
          fieldId: "labels"
          label:
            title: "Labels"
          valueExtractor:
            _type: "TagsSource"
          display:
            _type: "TagDisplay"
            singular: "label"
      about:
        _type: "ComponentTypeAbout"
        fields: ["health", "type", "labels"]
      events:
        _type: "ComponentTypeEvents"
        showEvents: true
        relatedResourcesTemplate: |
            (withNeighborsOf(direction = "up", components = (type = "otel service instance" and label = "service.name:{COMPONENT_NAME}"), levels = "1") and type = "otel service")
              OR
            (type = "otel service instance" and label = "service.name:{COMPONENT_NAME}")
              OR
            id = "{COMPONENT_ID}"
      showLogs: false
      showLastChange: false
      externalComponent:
        _type: "ComponentTypeExternalComponent"
        showConfiguration: false
        showStatus: false
        externalIdSelector: "^suse-ai:"
      relatedResources:
        - _type: "ComponentTypeRelatedResources"
          resourceType: "service instance"
          title: "Related service instances"
          stql: 'type = "otel service instance" and label = "service.name:{COMPONENT_NAME}"'
          viewTypeIdentifier: "urn:stackpack:open-telemetry:shared:view-type:service-instance"
        - _type: "ComponentTypeRelatedResources"
          resourceType: "service"
          title: "Related services"
          stql: 'withNeighborsOf(direction = "up", components = (type = "otel service instance" and label = "service.name:{COMPONENT_NAME}"), levels = "1") and type = "otel service"'
          viewTypeIdentifier: "urn:stackpack:open-telemetry:shared:view-type:service"
      metrics:
        - _type: "ComponentTypeMetricCategory"
          name: "GenAI"
          description: "GenAI Usage Metrics"
          bindings:
            - "urn:stackpack:suse-ai:shared:metric-binding:request-rate"
            - "urn:stackpack:suse-ai:shared:metric-binding:operation-duration-p95"
            - "urn:stackpack:suse-ai:shared:metric-binding:average-tokens-per-request"
            - "urn:stackpack:suse-ai:shared:metric-binding:token-usage-by-type"
          defaultExpanded: true
        - _type: "ComponentTypeMetricCategory"
          name: "Extension Metrics"
          description: "GenAI Usage Metrics"
          bindings:
            - "urn:stackpack:suse-ai:shared:metric-binding:total-usage-cost"
          defaultExpanded: false

