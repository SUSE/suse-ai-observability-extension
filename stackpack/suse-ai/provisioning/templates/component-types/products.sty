  # ViewType for ui.open-webui with traces support
  - _type: "ViewType"
    name: "Open WebUI view definition"
    identifier: "urn:stackpack:suse-ai:shared:view-type:ui.open-webui"
    filters:
      - _type: "TopologyFilters"
        tabs:
          - "EVENTS"
          - "TRACES"
    flags:
      - "NoTopologyFilters"
    overview:
      columns:
        - _type: "ViewTypeTableColHealth"
        - _type: "ViewTypeTableColName"
          title: "Component"

  # Define which traces to show for Open WebUI component
  - _type: TraceBinding
    name: Traces for Open WebUI
    identifier: urn:stackpack:suse-ai:shared:trace-binding:ui.open-webui
    filter:
      attributes:
        suse.ai.component.name: ["open-webui"]
    scope: (type = "ui.open-webui")

  # Show a link to Open WebUI component on span details
  - _type: SpanToComponentBinding
    name: Span binding to Open WebUI
    identifier: urn:stackpack:suse-ai:shared:span-to-component-binding:ui.open-webui
    urnTemplate: "suse-ai:product:ui:open-webui"
